# Copiar este archivo como `.env` y completar con las claves reales.
# El `.env` real NUNCA se commitea (está en .gitignore).

# API key de Anthropic (console.anthropic.com → API Keys)
EXPO_PUBLIC_ANTHROPIC_API_KEY=sk-ant-...

# Token de la integración interna de Notion (notion.so/my-integrations)
EXPO_PUBLIC_NOTION_TOKEN=ntn_...
