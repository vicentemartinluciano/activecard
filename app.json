{
  "expo": {
    "name": "ActiveCard",
    "slug": "activecard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "activecard",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0B0B0F",
    "android": {
      "package": "com.marti.activecard",
      "adaptiveIcon": {
        "backgroundColor": "#0B0B0F",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.marti.activecard",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "ActiveCard convierte tu voz en texto para el Gimnasio Mental.",
        "NSMicrophoneUsageDescription": "ActiveCard usa el micrófono para dictar tus conexiones de ideas."
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B0B0F",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      [
        "@jamsch/expo-speech-recognition",
        {
          "microphonePermission": "ActiveCard usa el micrófono para dictar tus conexiones de ideas.",
          "speechRecognitionPermission": "ActiveCard convierte tu voz en texto para el Gimnasio Mental."
        }
      ],
      "expo-sqlite",
      "expo-sharing"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c0ae7728-da97-4e4c-ae55-c8a010375d8c"
      }
    },
    "owner": "vicentemartinluciano"
  }
}
